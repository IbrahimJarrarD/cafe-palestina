---
import type { Language } from '../i18n/translations';
import type { EventWithRelations } from '../lib/database.types';
import { t } from '../i18n/translations';
import { getEventTitle, getEventDescription, getCategoryName } from '../lib/events';
import { sanitizeHtml } from '../lib/sanitize';
import EventImage from './EventImage.astro';

interface Props {
  event: EventWithRelations;
  lang: Language;
  index?: number;
}

const { event, lang, index = 0 } = Astro.props;
const tr = t(lang);

// Format date
const dateObj = new Date(event.date);
const localeMap = { de: 'de-DE', en: 'en-US', ar: 'ar-EG' };
const formattedDate = dateObj.toLocaleDateString(localeMap[lang], {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const title = getEventTitle(event, lang);
const description = getEventDescription(event, lang);
const categoryName = getCategoryName(event.category, lang);
const categoryIcon = event.category?.icon || '📅';
const categoryColor = event.category?.color || '#6b8c42';

// Image - prefer uploaded image, fall back to type-based SVG
const imageUrl = event.image_url;
const imageSlug = event.image_type?.slug || 'general';

// Prepare event data for modal (simplified for JSON)
const eventForModal = {
  id: event.id,
  slug: event.slug,
  date: event.date,
  time: event.time,
  location: event.location,
  address: event.address,
  title_de: event.title_de,
  title_en: event.title_en,
  title_ar: event.title_ar,
  description_de: event.description_de,
  description_en: event.description_en,
  description_ar: event.description_ar,
  category_name_de: event.category?.name_de || '',
  category_name_en: event.category?.name_en || '',
  category_name_ar: event.category?.name_ar || '',
  category_icon: categoryIcon,
  image_url: imageUrl,
  image_slug: imageSlug,
  video_url: event.video_url || '',
};
---

<article 
  class="event-card" 
  data-event={JSON.stringify(eventForModal)}
  style={`--delay: ${index * 0.1}s; --category-color: ${categoryColor}`}
>
  <div class="card-image">
    {imageUrl ? (
      <img src={imageUrl} alt={title} class="event-photo" loading="lazy" />
    ) : (
      <EventImage icon={categoryIcon} color={categoryColor} type={imageSlug} />
    )}
    <span class="card-badge">
      <span class="badge-icon">{categoryIcon}</span>
      {categoryName}
    </span>
  </div>
  
  <div class="card-content">
    <h3 class="card-title">{title}</h3>
    
    <div class="card-meta">
      <div class="meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span>{formattedDate}</span>
      </div>
      <div class="meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>{event.time}</span>
      </div>
      <div class="meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span>{event.location}</span>
      </div>
    </div>
    
    <div class="card-description" set:html={sanitizeHtml(description)} />
    
    <button class="card-btn" data-open-modal>
      {tr.events.learnMore}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </button>
  </div>
</article>

<style>
  .event-card {
    background: var(--white);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(26, 61, 46, 0.06);
    border: 1px solid rgba(26, 61, 46, 0.05);
    transition: all 0.4s var(--ease-spring);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    animation: cardFadeIn 0.6s var(--ease-out) var(--delay) both;
  }
  
  @keyframes cardFadeIn {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .event-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(26, 61, 46, 0.15);
  }
  
  .card-image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  
  .event-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .card-badge {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    padding: var(--space-xs) var(--space-md);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--pine);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 4px;
    border-left: 3px solid var(--category-color);
  }
  
  .badge-icon {
    font-size: 0.9rem;
  }
  
  :global([dir="rtl"]) .card-badge {
    right: auto;
    left: var(--space-md);
    border-left: none;
    border-right: 3px solid var(--category-color);
  }
  
  .card-content {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  
  .card-title {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--pine);
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }
  
  .card-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  
  .meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--ink-light);
  }
  
  .meta-item svg {
    color: var(--olive);
    flex-shrink: 0;
  }
  
  .card-description {
    font-size: 0.9rem;
    color: var(--ink-light);
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: var(--space-lg);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-description :global(h2),
  .card-description :global(h3) {
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0;
    display: inline;
  }

  .card-description :global(p) {
    margin: 0;
  }

  .card-description :global(ul),
  .card-description :global(ol) {
    margin: 0;
    padding-left: 1rem;
  }
  
  .card-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    background: linear-gradient(135deg, var(--olive) 0%, var(--olive-light) 100%);
    color: var(--white);
    font-size: 0.9rem;
    font-weight: 600;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s var(--ease-out);
    align-self: flex-start;
  }
  
  .card-btn:hover {
    transform: translateX(4px);
    box-shadow: 0 4px 15px rgba(107, 140, 66, 0.35);
  }
  
  :global([dir="rtl"]) .card-btn:hover {
    transform: translateX(-4px);
  }
  
  .card-btn svg {
    transition: transform 0.3s var(--ease-out);
  }
  
  .card-btn:hover svg {
    transform: translateX(4px);
  }
  
  :global([dir="rtl"]) .card-btn svg {
    transform: scaleX(-1);
  }
  
  :global([dir="rtl"]) .card-btn:hover svg {
    transform: scaleX(-1) translateX(-4px);
  }
</style>
