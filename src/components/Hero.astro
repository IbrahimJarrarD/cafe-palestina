---
import type { Language } from '../i18n/translations';
import { t } from '../i18n/translations';
import { getActiveAnnouncement, getAnnouncementText, getPageContent, getContent } from '../lib/content';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const tr = t(lang);

// Fetch dynamic content
const announcement = await getActiveAnnouncement();
const pageContent = await getPageContent();

// Get announcement data
const announcementText = announcement ? getAnnouncementText(announcement, lang) : '';
const announcementIcon = announcement?.icon || '🌿';
const announcementLink = announcement?.link_url || '#events';
const isExternalLink = announcement?.link_type === 'external';

// Get hero content from DB
const heroTitle = getContent(pageContent, 'hero_title', lang) || '';
const heroSubtitle = getContent(pageContent, 'hero_subtitle', lang) || '';
const poemText = getContent(pageContent, 'poem_text', lang) || '';
const poemAuthor = getContent(pageContent, 'poem_author', lang) || '';
---

<section class="hero" id="home">
  <div class="hero-bg">
    <div class="hero-pattern"></div>
    <div class="hero-gradient"></div>
  </div>
  
  <div class="container hero-content">
    <a 
      href={announcementLink} 
      class="hero-badge"
      target={isExternalLink ? '_blank' : undefined}
      rel={isExternalLink ? 'noopener' : undefined}
    >
      <span class="badge-icon">{announcementIcon}</span>
      <span>{announcementText}</span>
      <svg class="badge-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
    
    <h1 class="hero-title">{heroTitle}</h1>
    <p class="hero-subtitle">{heroSubtitle}</p>
    
    <div class="hero-cta">
      <a href="#events" class="btn btn-primary">
        {tr.hero.cta}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="#about" class="btn btn-secondary">{tr.hero.ctaSecondary}</a>
    </div>
    
    <div class="hero-poem">
      <blockquote>
        <p>{poemText}</p>
        <footer>{poemAuthor}</footer>
      </blockquote>
    </div>
  </div>
  
  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(72px + var(--space-4xl)) var(--space-lg) var(--space-4xl);
    overflow: hidden;
  }
  
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  
  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 0 L80 40 L40 80 L0 40 Z' fill='none' stroke='%236b8c42' stroke-width='0.5' opacity='0.15'/%3E%3C/svg%3E");
    background-size: 80px 80px;
    opacity: 0.5;
    animation: patternFloat 30s linear infinite;
  }
  
  @keyframes patternFloat {
    0% { transform: translate(0, 0); }
    100% { transform: translate(80px, 80px); }
  }
  
  .hero-gradient {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 20% 0%, rgba(107, 140, 66, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 100%, rgba(212, 168, 83, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(250, 248, 244, 0.9) 0%, var(--cream) 100%);
  }
  
  .hero-content {
    text-align: center;
    max-width: 800px;
    position: relative;
    z-index: 1;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    background: var(--white);
    border: 1px solid rgba(107, 140, 66, 0.2);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--pine);
    margin-bottom: var(--space-xl);
    box-shadow: 0 4px 20px rgba(26, 61, 46, 0.06);
    animation: fadeInUp 0.6s var(--ease-out) 0.1s both;
    text-decoration: none;
    transition: all 0.3s var(--ease-out);
    cursor: pointer;
  }
  
  .hero-badge:hover {
    background: var(--sand-light);
    border-color: var(--olive);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(26, 61, 46, 0.12);
  }
  
  .badge-icon {
    font-size: 1rem;
  }
  
  .badge-arrow {
    opacity: 0;
    transform: translateX(-5px);
    transition: all 0.3s var(--ease-out);
    color: var(--olive);
  }
  
  .hero-badge:hover .badge-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  
  :global([dir="rtl"]) .badge-arrow {
    transform: scaleX(-1) translateX(5px);
  }
  
  :global([dir="rtl"]) .hero-badge:hover .badge-arrow {
    transform: scaleX(-1) translateX(0);
  }
  
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--pine);
    margin-bottom: var(--space-lg);
    letter-spacing: -0.03em;
    line-height: 1.1;
    animation: fadeInUp 0.6s var(--ease-out) 0.2s both;
  }
  
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--ink-light);
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
    line-height: 1.7;
    animation: fadeInUp 0.6s var(--ease-out) 0.3s both;
  }
  
  .hero-cta {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-4xl);
    animation: fadeInUp 0.6s var(--ease-out) 0.4s both;
  }
  
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s var(--ease-out);
  }
  
  .btn-primary {
    background: linear-gradient(135deg, var(--pine) 0%, var(--pine-light) 100%);
    color: var(--white);
    box-shadow: 0 4px 20px rgba(26, 61, 46, 0.25);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(26, 61, 46, 0.35);
  }
  
  .btn-primary svg {
    transition: transform 0.3s var(--ease-out);
  }
  
  .btn-primary:hover svg {
    transform: translateX(4px);
  }
  
  .btn-secondary {
    background: var(--white);
    color: var(--pine);
    border: 2px solid var(--pine);
  }
  
  .btn-secondary:hover {
    background: var(--pine);
    color: var(--white);
  }
  
  .hero-poem {
    max-width: 600px;
    margin: 0 auto;
    animation: fadeInUp 0.6s var(--ease-out) 0.5s both;
  }
  
  .hero-poem blockquote {
    position: relative;
    padding: var(--space-xl);
    background: linear-gradient(135deg, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.4) 100%);
    border-radius: 16px;
    border-left: 4px solid var(--olive);
  }
  
  .hero-poem p {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    color: var(--ink-light);
    line-height: 1.9;
    white-space: pre-line;
    margin-bottom: var(--space-md);
  }
  
  :global(body.rtl) .hero-poem blockquote {
    border-left: none;
    border-right: 4px solid var(--olive);
  }
  
  .hero-poem footer {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--olive);
  }
  
  .hero-scroll {
    position: absolute;
    bottom: var(--space-2xl);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    color: var(--ink-light);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    animation: fadeIn 0.6s var(--ease-out) 1s both;
  }
  
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--olive), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }
  
  @media (max-width: 768px) {
    .hero {
      padding-top: calc(72px + var(--space-2xl));
    }
    
    .hero-poem blockquote {
      padding: var(--space-lg);
    }
    
    .hero-scroll {
      display: none;
    }
  }
</style>
