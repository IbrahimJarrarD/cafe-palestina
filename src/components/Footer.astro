---
import type { Language } from '../i18n/translations';
import { t } from '../i18n/translations';
import { getSiteSettings, getSetting, getPageContent, getContent } from '../lib/content';
import Logo from './Logo.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const tr = t(lang);

// Fetch dynamic content
const settings = await getSiteSettings();
const pageContent = await getPageContent();

// Get settings
const email = getSetting(settings, 'email') || 'info@cafepalestine.de';
const addressStreet = getSetting(settings, 'address_street') || 'Geisselstraße 3–5';
const addressCity = getSetting(settings, 'address_city') || '50823 Köln';
const addressCountry = getSetting(settings, 'address_country') || 'Deutschland';
const instagramUrl = getSetting(settings, 'instagram_url');
const facebookUrl = getSetting(settings, 'facebook_url');
const youtubeUrl = getSetting(settings, 'youtube_url');

// Get footer description from page content
const footerDesc = getContent(pageContent, 'footer_description', lang) || tr.footer.contact;

// Current year for copyright
const currentYear = new Date().getFullYear();

// Language-aware legal page links
const langPrefix = lang === 'de' ? '' : `/${lang}`;
const impressumUrl = `${langPrefix}/impressum`;
const datenschutzUrl = `${langPrefix}/datenschutz`;
---

<footer class="footer" id="contact">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <Logo />
        </a>
        <p class="footer-desc">{footerDesc}</p>
      </div>
      
      <div class="footer-section">
        <h4>{tr.footer.contact}</h4>
        <address>
          <p>{addressStreet}</p>
          <p>{addressCity}, {addressCountry}</p>
          <a href={`mailto:${email}`}>{email}</a>
        </address>
      </div>
      
      <div class="footer-section">
        <h4>{tr.footer.quickLinks}</h4>
        <nav class="footer-nav">
          <a href="#events">{tr.nav.events}</a>
          <a href="#about">{tr.nav.about}</a>
          <a href="#contact">{tr.footer.contact}</a>
          <a href={impressumUrl}>{tr.footer.impressum}</a>
          <a href={datenschutzUrl}>{tr.footer.privacy}</a>
          <a href="/admin/login" class="admin-link">Admin</a>
        </nav>
      </div>
      
      <div class="footer-section">
        <h4>{tr.footer.follow}</h4>
        <div class="social-links">
          {instagramUrl && (
            <a href={instagramUrl} target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          )}
          {facebookUrl && (
            <a href={facebookUrl} target="_blank" rel="noopener" class="social-link" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          )}
          {youtubeUrl && (
            <a href={youtubeUrl} target="_blank" rel="noopener" class="social-link" aria-label="YouTube">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>© {currentYear} Cafe Palestine Colonia. All rights reserved.</p>
      <div class="footer-flag" title="Palestine">
        <div class="flag-stripe flag-black"></div>
        <div class="flag-stripe flag-white"></div>
        <div class="flag-stripe flag-green"></div>
        <div class="flag-triangle"></div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--pine);
    color: var(--sand-light);
    padding: var(--space-4xl) 0 var(--space-xl);
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
  }
  
  .footer-brand {
    max-width: 280px;
  }
  
  .footer-logo {
    display: inline-block;
    margin-bottom: var(--space-lg);
    text-decoration: none;
  }
  
  .footer-logo :global(.logo-img) {
    width: 60px;
    height: 60px;
    border-radius: 12px;
  }
  
  .footer-desc {
    font-size: 0.9rem;
    color: rgba(232, 220, 196, 0.8);
    line-height: 1.7;
  }
  
  .footer-section h4 {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold);
    margin-bottom: var(--space-lg);
  }
  
  .footer-section address {
    font-style: normal;
    font-size: 0.9rem;
    line-height: 1.8;
  }
  
  .footer-section a {
    color: var(--sand-light);
    text-decoration: none;
    transition: color 0.2s;
    display: block;
  }
  
  .footer-section a:hover {
    color: var(--gold);
  }
  
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  
  .admin-link {
    opacity: 0.5;
    font-size: 0.8rem;
    margin-top: var(--space-sm);
  }
  
  .admin-link:hover {
    opacity: 1;
  }
  
  .social-links {
    display: flex;
    gap: var(--space-sm);
  }
  
  .social-link {
    width: 44px;
    height: 44px;
    display: flex !important;
    align-items: center;
    justify-content: center;
    background: rgba(232, 220, 196, 0.1);
    border-radius: 10px;
    color: var(--sand-light);
    transition: all 0.2s;
  }
  
  .social-link:hover {
    background: var(--gold);
    color: var(--pine);
    transform: translateY(-2px);
  }
  
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(232, 220, 196, 0.1);
  }
  
  .footer-bottom p {
    font-size: 0.85rem;
    color: rgba(232, 220, 196, 0.6);
  }
  
  /* Palestinian Flag */
  .footer-flag {
    width: 48px;
    height: 32px;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }
  
  .flag-stripe {
    height: 33.33%;
    width: 100%;
  }
  
  .flag-black {
    background: #000000;
  }
  
  .flag-white {
    background: #ffffff;
  }
  
  .flag-green {
    background: #007a3d;
  }
  
  .flag-triangle {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-top: 16px solid transparent;
    border-bottom: 16px solid transparent;
    border-left: 16px solid #ce1126;
  }
  
  :global([dir="rtl"]) .flag-triangle {
    left: auto;
    right: 0;
    border-left: none;
    border-right: 16px solid #ce1126;
  }
  
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
    
    .footer-brand {
      grid-column: span 2;
      max-width: none;
    }
  }
  
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    
    .footer-brand {
      grid-column: span 1;
    }
    
    .footer-bottom {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }
  }
</style>
