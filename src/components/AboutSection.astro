---
import type { Language } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section class="about-section" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-content">
        <span class="section-label">🌿 {tr.about.title}</span>
        <h2 class="about-title">{tr.about.title}</h2>
        <p class="about-text">{tr.about.text1}</p>
        <p class="about-text">{tr.about.text2}</p>
        
        <div class="about-highlight">
          <h3>{tr.about.whyTitle}</h3>
          <p>{tr.about.whyText}</p>
        </div>
      </div>
      
      <div class="about-visual">
        <div class="visual-card">
          <img src="/logo.jpg" alt="Cafe Palestine Colonia" class="about-logo" />
        </div>
        
        <div class="visual-stats">
          <div class="stat">
            <span class="stat-number">100+</span>
            <span class="stat-label">{{ de: 'Veranstaltungen', en: 'Events', ar: 'فعالية' }[lang]}</span>
          </div>
          <div class="stat">
            <span class="stat-number">5k+</span>
            <span class="stat-label">{{ de: 'Besucher', en: 'Visitors', ar: 'زائر' }[lang]}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: var(--space-4xl) 0;
    background: var(--sand-light);
    position: relative;
    overflow: hidden;
  }
  
  .about-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--olive), transparent);
    opacity: 0.3;
  }
  
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }
  
  .section-label {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    background: var(--white);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--olive);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-md);
  }
  
  .about-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--pine);
    margin-bottom: var(--space-xl);
  }
  
  .about-text {
    font-size: 1rem;
    color: var(--ink-light);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }
  
  .about-highlight {
    padding: var(--space-xl);
    background: var(--white);
    border-radius: 16px;
    border-left: 4px solid var(--olive);
    margin-top: var(--space-xl);
  }
  
  :global([dir="rtl"]) .about-highlight {
    border-left: none;
    border-right: 4px solid var(--olive);
  }
  
  .about-highlight h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--pine);
    margin-bottom: var(--space-sm);
  }
  
  .about-highlight p {
    font-size: 0.95rem;
    color: var(--ink-light);
    line-height: 1.7;
    margin: 0;
  }
  
  .about-visual {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  
  .visual-card {
    background: var(--white);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(26, 61, 46, 0.1);
  }
  
  .about-logo {
    width: 100%;
    height: auto;
    display: block;
    padding: var(--space-2xl);
    object-fit: contain;
  }
  
  .visual-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }
  
  .stat {
    background: var(--white);
    padding: var(--space-xl);
    border-radius: 16px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(26, 61, 46, 0.06);
  }
  
  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--pine);
    line-height: 1;
  }
  
  .stat-label {
    display: block;
    font-size: 0.85rem;
    color: var(--ink-light);
    margin-top: var(--space-sm);
  }
  
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    
    .about-visual {
      order: -1;
    }
  }
</style>

