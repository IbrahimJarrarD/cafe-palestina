---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import EventsSection from '../../components/EventsSection.astro';
import AboutSection from '../../components/AboutSection.astro';
import Newsletter from '../../components/Newsletter.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
---

<Layout 
  title="Cafe Palestine Colonia – Cultural Events & Community"
  description="A cultural center in Cologne celebrating the connection between Palestinian and German culture. Workshops, readings, film nights and more."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <EventsSection lang={lang} />
    <AboutSection lang={lang} />
    <Newsletter lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>

