---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import EventsSection from '../components/EventsSection.astro';
import AboutSection from '../components/AboutSection.astro';
import Footer from '../components/Footer.astro';

const lang = 'de';
---

<Layout
  title="Cafe Palestine Colonia – Kulturelle Veranstaltungen & Gemeinschaft"
  description="Ein kulturelles Zentrum in Köln, das die Verbindung zwischen palästinensischer und deutscher Kultur feiert. Workshops, Lesungen, Filmabende und mehr."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <EventsSection lang={lang} />
    <AboutSection lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
