---
// Signup is disabled — admin accounts are created manually via Supabase dashboard
// This prevents unauthorized account creation
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Registration Disabled | Cafe Palestine Colonia</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="icon">🔒</div>
      <h1>Registration Disabled</h1>
      <p>Account creation is not available. Admin accounts are managed internally.</p>
      <p class="hint">If you need access, contact the site administrator.</p>
      <div class="actions">
        <a href="/admin/login" class="btn btn-primary">Go to Login</a>
        <a href="/" class="btn btn-secondary">Back to Website</a>
      </div>
    </div>
  </div>
</body>
</html>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: linear-gradient(135deg, #1a3d2e 0%, #2d5a47 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .container { width: 100%; max-width: 420px; }

  .card {
    background: #ffffff;
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    text-align: center;
  }

  .icon { font-size: 3rem; margin-bottom: 1.5rem; }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a3d2e;
    margin-bottom: 0.75rem;
  }

  p { color: #6b7280; font-size: 0.95rem; margin-bottom: 0.5rem; }

  .hint { font-size: 0.85rem; color: #9ca3af; margin-top: 0.5rem; }

  .actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .btn {
    display: block;
    padding: 0.875rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    text-align: center;
    transition: all 0.2s;
  }

  .btn-primary {
    background: linear-gradient(135deg, #1a3d2e 0%, #2d5a47 100%);
    color: #ffffff;
  }

  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(26, 61, 46, 0.3); }

  .btn-secondary {
    background: transparent;
    color: #6b7280;
    border: 2px solid #e8dcc4;
  }

  .btn-secondary:hover { border-color: #1a3d2e; color: #1a3d2e; }
</style>
