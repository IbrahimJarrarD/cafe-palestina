---
import AdminLayout from '../../layouts/AdminLayout.astro';
import SettingsEditor from '../../components/admin/SettingsEditor.svelte';
import { supabase } from '../../lib/supabase';

const { data: settings } = await supabase
  .from('site_settings')
  .select('*')
  .order('key', { ascending: true });
---

<AdminLayout title="Site Settings" activeSection="settings">
  <div class="settings-page">
    <div class="page-header">
      <p class="subtitle">Configure contact info, social links, and other settings</p>
    </div>
    
    <SettingsEditor client:load settings={settings || []} />
  </div>
</AdminLayout>

<style>
  .settings-page {
    max-width: 700px;
  }
  
  .page-header {
    margin-bottom: 1.5rem;
  }
  
  .subtitle {
    color: var(--ink-light);
    font-size: 0.9rem;
  }
</style>

